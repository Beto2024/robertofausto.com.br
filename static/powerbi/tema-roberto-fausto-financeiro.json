{
  "name": "Roberto Fausto — Dashboard Financeiro",
  "dataColors": [
    "#22C55E",
    "#4ADE80",
    "#16A34A",
    "#86EFAC",
    "#15803D",
    "#DCFCE7",
    "#166534",
    "#BBF7D0",
    "#10B981",
    "#EF4444"
  ],
  "background": "#0F172A",
  "foreground": "#F1F5F9",
  "tableAccent": "#22C55E",
  "maximum": "#10B981",
  "center": "#F59E0B",
  "minimum": "#EF4444",
  "good": "#10B981",
  "neutral": "#94A3B8",
  "bad": "#EF4444",
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#1E293B" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "color": { "solid": { "color": "#334155" } },
            "show": true,
            "radius": 12
          }
        ],
        "visualHeader": [
          {
            "show": false
          }
        ],
        "*": [
          {
            "fontFamily": "Segoe UI",
            "fontSize": 11,
            "color": { "solid": { "color": "#94A3B8" } }
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#0F172A" } },
            "transparency": 0
          }
        ],
        "wallpaper": [
          {
            "color": { "solid": { "color": "#0F172A" } },
            "transparency": 0
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": { "solid": { "color": "#F1F5F9" } },
            "fontSize": 28,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "categoryLabels": [
          {
            "color": { "solid": { "color": "#64748B" } },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    },
    "lineChart": {
      "*": {
        "dataPoint": [
          {
            "defaultColor": { "solid": { "color": "#22C55E" } }
          }
        ],
        "lineStyles": [
          {
            "strokeWidth": 3
          }
        ]
      }
    },
    "barChart": {
      "*": {
        "dataPoint": [
          {
            "defaultColor": { "solid": { "color": "#22C55E" } }
          }
        ]
      }
    },
    "columnChart": {
      "*": {
        "dataPoint": [
          {
            "defaultColor": { "solid": { "color": "#22C55E" } }
          }
        ]
      }
    },
    "waterfallChart": {
      "*": {
        "sentimentColors": [
          {
            "increaseFill": { "solid": { "color": "#10B981" } },
            "decreaseFill": { "solid": { "color": "#EF4444" } },
            "totalFill": { "solid": { "color": "#3B82F6" } }
          }
        ]
      }
    },
    "treemap": {
      "*": {
        "dataPoint": [
          {
            "defaultColor": { "solid": { "color": "#22C55E" } }
          }
        ]
      }
    },
    "gauge": {
      "*": {
        "dataPoint": [
          {
            "target": { "solid": { "color": "#F59E0B" } },
            "fill": { "solid": { "color": "#22C55E" } }
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "general": [
          {
            "outlineColor": { "solid": { "color": "#334155" } },
            "outlineWeight": 1
          }
        ]
      }
    }
  }
}